# DeepSeek-compatible LLM API key.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Current DeepSeek API model.
DEEPSEEK_MODEL=deepseek-v4-pro

# V4 Pro thinking mode improves answer reliability.
DEEPSEEK_THINKING=enabled
DEEPSEEK_REASONING_EFFORT=high
LOOP_LLM_TIMEOUT_SECONDS=8

# Nightly Sync should stay low-latency and avoid thinking-mode timeouts.
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_CHAT_THINKING=disabled
LOOP_CHAT_LLM_TIMEOUT_SECONDS=25
LOOP_DEEP_CHAT_LLM_TIMEOUT_SECONDS=60
LOOP_CHAT_MAX_TOKENS=600
LOOP_DEEP_CHAT_MAX_TOKENS=1200

# Loop chat uses LangGraph so Router-Actor memory updates cannot be bypassed.
LOOP_CHAT_ENGINE=graph

# High-reliability RAG: vector recall + cross-encoder rerank, preloaded on startup.
LOOP_VECTOR_RAG_ENABLED=true
LOOP_RERANKER_ENABLED=true
LOOP_RAG_PRELOAD=true
LOOP_RAG_STRICT=true
LOOP_EMBEDDING_DEVICE=cuda:0
LOOP_RERANKER_DEVICE=cuda:1

# Keep classification on the LLM path for higher-quality routing decisions.
LOOP_CORE_MEMORY_INTENT_LLM_ENABLED=true
LOOP_TOPIC_ROUTER_LLM_ENABLED=true

# Browser origins allowed to call FastAPI through the SSH tunnel.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Host headers accepted by FastAPI. Keep this local-only for tunnel access.
LOOP_ALLOWED_HOSTS=localhost,127.0.0.1

# Generate strong random values before deploying.
LOOP_AUTH_SECRET=replace_with_a_long_random_token
LOOP_ADMIN_API_KEY=replace_with_a_long_random_admin_key

# Optional API hardening knobs.
LOOP_ACCESS_TOKEN_TTL_SECONDS=86400
LOOP_MAX_REQUEST_BYTES=524288
LOOP_RATE_LIMIT_REQUESTS=120
LOOP_RATE_LIMIT_WINDOW_SECONDS=60
LOOP_TRUST_X_FORWARDED_FOR=false
